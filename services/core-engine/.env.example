PORT=4001
DATABASE_URL=postgres://username:password@localhost:5432/codehaat
REDIS_URL=redis://:your_redis_password@redis:6379
JWT_SECRET=your-secret-key-here-change-in-production
# Must match apps/web JWT_SECRET (used by Next.js middleware to verify tokens)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# SeaweedFS (S3-compatible object storage)
S3_ENDPOINT=http://localhost:8333
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=codehaat-media
S3_REGION=us-east-1
S3_PUBLIC_URL=/api/images

# Razorpay (TEST mode — use rzp_test_ keys)
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_YOUR_TEST_KEY_ID
RAZORPAY_KEY_SECRET=your_test_key_secret
# Webhook secret from: https://dashboard.razorpay.com/app/webhooks
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
# Public base URL of the frontend (used in reset links, etc.)
APP_BASE_URL=http://localhost:3000
