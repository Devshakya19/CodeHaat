# Server-side (NOT exposed to browser — no NEXT_PUBLIC prefix)
# Must match services/core-engine JWT_SECRET exactly.
# Used by Next.js middleware to cryptographically verify auth tokens.
JWT_SECRET=your-secret-key-here-change-in-production
# Internal backend URL used by the /api/proxy route (server-side only).
API_URL=http://localhost:4001

# Client-side (exposed to browser — NEXT_PUBLIC prefix)
# Razorpay TEST mode public key (rzp_test_...). Same as RAZORPAY_KEY_ID in core-engine.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_YOUR_TEST_KEY_ID
# Public API URL (kept for backward compat; authed calls go through /api/proxy).
NEXT_PUBLIC_API_URL=http://localhost:4001
